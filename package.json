{
	"name": "@bucky24/react-canvas",
	"version": "3.2.2",
	"description": "A library of components that can be used to manipulate a canvas using JSX embedded in react.",
	"main": "build/index.js",
	"scripts": {
		"clean": "rm -rf build",
		"build": "babel src --out-dir build",
		"basicExample": "vite --config examples/basicExample/vite.config.js",
		"resizeExample": "vite --config examples/resizeExample/vite.config.js",
		"eventExample": "vite --config examples/eventExample/vite.config.js",
		"imageExample": "vite --config examples/imageExample/vite.config.js",
		"extendingExample": "vite --config examples/extendingExample/vite.config.js",
		"overlapExample": "vite --config examples/overlapExample/vite.config.js",
		"clipExample": "vite --config examples/clipExample/vite.config.js",
		"renderExample": "vite --config examples/renderExample/vite.config.js",
		"blendExample": "vite --config examples/blendExample/vite.config.js",
		"compoundExample": "vite --config examples/compoundExample/vite.config.js",
		"animationExample": "vite --config examples/animationExample/vite.config.js",
		"autoCompoundExample": "vite --config examples/autoCompoundExample/vite.config.js",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"build"
	],
	"author": "Bucky24",
	"license": "ISC",
	"homepage": "https://github.com/Bucky24/react-canvas#readme",
	"devDependencies": {
		"@babel/cli": "7.16.7",
		"@babel/core": "7.4.0",
		"@babel/plugin-proposal-class-properties": "7.10.1",
		"@babel/plugin-transform-react-jsx": "7.3.0",
		"@babel/plugin-transform-runtime": "7.17.0",
		"@babel/preset-env": "7.3.1",
		"@babel/preset-react": "7.0.0",
		"@babel/runtime": "^7.17.2",
		"@vitejs/plugin-react": "^4.3.4",
		"react": "19.2.5",
		"vite": "^6.3.3",
		"react-dom": "19.2.5"
	},
	"keywords": [
		"react",
		"canvas",
		"react-canvas",
		"drawing",
		"html5"
	],
	"dependencies": {
		"prop-types": "15.8.1",
		"react-fast-compare": "3.2.2"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	}
}
